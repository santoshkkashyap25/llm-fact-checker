[run]
# Measure coverage for everything under 'core', except the omitted files
source =
    core

omit =
    */__init__.py
    */__pycache__/*
    tests/*
    core/api.py
    core/metrics.py
    core/data_scraper.py

[report]
# Lines to ignore in coverage computation
exclude_lines =
    pragma: no cover
    if __name__ == "__main__":
    def __repr__
    def __str__

# Show missing lines in the terminal
show_missing = True
